{
  "vars": {

	  
	-- ********************* -- 
	-- *      FUENTES      * -- 
    -- ********************* -- 

	  
    -- carpeta con los instaladores 
    "sourceDir":"D:/temp/MyTaskRunner", 
    
    -- instalador de vscode 
    "vscodeZip": "VSCode_v1.9.9.zip",

    -- proyecto empty 
    "emptyProject": "AlgoritmosAFondo_EMPTY_v2.7.27.zip",

    -- proyecto full 1C 
    "fullProject1C": "AlgoritmosAFondo_FULL1C_v2.7.27.zip",

    -- proyecto full 2C 
    "fullProject2C": "AlgoritmosAFondo_FULL2C_v2.7.27.zip",

    -- hello world project
	"helloWorldProject":"Proyecto_01",

    -- workspace config FileCopy
	"workspaceConfigFile":"Workspace.code-workspace",


	-- ********************* -- 
	-- *      DESTINOS     * -- 
    -- ********************* -- 


    -- carpeta temporal dónde voy a copiar provisoriamente
    "tempDir": "${sys:prop:java.io.tmpdir}/tmpProfSznajdleder",
    
    -- carpeta temporal dónde voy a instalar provisoriamente
    "tempDrive": "${tempDir}",

	-- home temporal TEMP
    "tempHome": "${tempDrive}/vscode",	

	-- workspace temporal TEMP
    "tempWorkspace": "${tempHome}/Workspace",	

    -- disco destinatario (toda la instalación será relativa a este disco)
    "targetDrive": "C:",
    
    -- vscode home FINAL
    "vscodeHome": "${targetDrive}/vscode",
    
    -- vscode workspace  FINAL
    "vscodeWorkspace": "${vscodeHome}/Workspace",

	-- filename para backupear el viejo workspace (antes de borrarlo)
    "workspaceBkp":"${sys:prop:user.home}/workspaceBkp_${time:now:yyyyMMdd-HHmm}.zip",	


  	-- ************************ --        
	-- *   TIPO INSTALACIÓN   * --        
    -- ************************ --        
	--                                    
	-- 0: Inicial/Básica  | vscode        
	-- 1: Primer parcial  | vscode+1C.zip 
	-- 2: Segundo parcial | vscode+2C.zip 

	"installType":1
  },  

  "steps": [    
    
    
	-- **************** --
	-- * Copio al tmp * --
	-- **************** --
	
		
	-- 1: vscode 
	{ "action":"FileCopy",
	  "from":"${sourceDir}/${vscodeZip}",
	  "to":"${tempDir}/",
	  "executeIf":"notExistsOrIsNewer",
	  "showProgress": true,
	  "stopScriptOnError":true
	  
	},
	
	-- 2: workspaceConfigFile 
	{ "action":"FileCopy",
	  "from":"${sourceDir}/${workspaceConfigFile}",
	  "to":"${tempDir}/",
	  "ifvar":"${installType} in (1,2)",
	  "executeIf":"notExistsOrIsNewer",
	  "showProgress": true,
	  "stopScriptOnError":true
	},
	  
	-- 3: 1C.zip 
	{ "action":"FileCopy",
	  "from":"${sourceDir}/${fullProject1C}",
	  "to":"${tempDir}/",
	  "ifvar":"${installType}==1",
	  "executeIf":"notExistsOrIsNewer",
	  "showProgress": true,
	  "stopScriptOnError":true
	},
	
	-- 4: copio 2C.zip a tmp SI installType==2 
	{ "action":"FileCopy",
	  "from":"${sourceDir}/${fullProject2C}",
	  "to":"${tempDir}/",
	  "ifvar":"${installType}==2",
	  "executeIf":"notExistsOrIsNewer",
	  "showProgress": true,
	  "stopScriptOnError":true
	},
	
	
	-- **************** --
	-- * Backup y rmv * --
	-- **************** --
	
	
	-- 5: workspaceBkp 
	{ "action": "Zip", 
	  "from":"${vscodeWorkspace}",
	  "to":"${workspaceBkp}",
	  "showProgress":true,
	  "stopScriptOnError":false
	},
	
	-- 6: Rmv anterior 
	{ "action":"Remove",
	  "from":"${vscodeHome}",
	  "showProgress":true,
	  "stopScriptOnError":true
	},
	
	-- 7: Rmv temp anterior 
	{ "action":"Remove",
	  "from":"${tempHome}",
	  "showProgress":true,
	  "stopScriptOnError":true
	},
	
	
	-- **************** --
	-- * Inst. VSCode * --
	-- **************** --
	
	
	-- 8: unzip vsCode 
	{ "action":"Unzip",
	  "from":"${tempDir}/${vscodeZip}",
	  "to":"${tempDrive}/",
	  "showProgress": true,
	  "stopScriptOnError":true
	},
	
	
	-- **************** --
	-- *  Inst. types * --
	-- **************** --
	
	  
	-- 9: rmv helloWorldProject 
	{ 
	  "action":"Remove",
	  "from":"${tempWorkspace}/${helloWorldProject}",
	  "ifvar":"${installType} in (1,2)",
	  "showProgress":true,
	  "stopScriptOnError":false
	},
	  
	-- 10: unzip 1C 
	{ 
	  "action":"Unzip",
	  "from":"${tempDir}/${fullProject1C}",
	  "to":"${tempWorkspace}/",
	  "ifvar":"${installType}==1",
	  "showProgress": true,
	  "stopScriptOnError":true 
	},
	
	-- 11: unzip 2C 
	{ 
	  "action":"Unzip",
	  "from":"${tempDir}/${fullProject2C}",
	  "to":"${tempWorkspace}/",
	  "ifvar":"${installType}==2",
	  "showProgress": true,
	  "stopScriptOnError":true
	},
	
	-- 12: fileCopy workspaceConfigFile
	{ 
	  "action":"FileCopy",
	  "from":"${tempDir}/${workspaceConfigFile}",
	  "to":"${tempWorkspace}/",
	  "ifvar":"${installType} in (1,2)",
	  "showProgress": true,
	  "stopScriptOnError":true
	},
	
	-- 13: copy temp->final
	{ 
	  "action":"DirCopy",
	  "from":"${tempHome}",
	  "to":"${targetDrive}/",
	  "showProgress": true,
	  "stopScriptOnError":true
	},
	
	-- 14: cleanup temp
	{
	  "action":"Remove",
	  "from":"${tempHome}",
	  "showProgress": true,
	  "stopScriptOnError":true
	},

    -- 15: levanto vscode 
    { 
    	"action":"Exec",
    	"command":"${vscodeHome}/RunVSCode.bat ${targetDrive}" 
    }
  ]
}

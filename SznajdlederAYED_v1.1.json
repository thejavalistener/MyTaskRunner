{
  "vars": {
	  
	-- ********************* -- 
	-- *      FUENTES      * -- 
    -- ********************* -- 
	  
	  
    -- carpeta con los instaladores 
    "sourceDir":"D:/temp/MyTaskRunner", 
    
    -- instalador de vscode 
    "vscodeZip": "VSCode_v1.9.9.zip",

    -- proyecto empty 
    "emptyProject": "AlgoritmosAFondo_EMPTY_v2.7.27.zip",

    -- proyecto full 1C 
    "fullProject1C": "AlgoritmosAFondo_FULL1C_v2.7.27.zip",

    -- proyecto full 2C 
    "fullProject2C": "AlgoritmosAFondo_FULL2C_v2.7.27.zip",

    -- hello world project
	"helloWorldProject":"Proyecto_01",

    -- workspace config FileCopy
	"workspaceConfigFile":"Workspace.code-workspace",


	-- ********************* -- 
	-- *      DESTINOS     * -- 
    -- ********************* -- 


    -- carpeta temporal dónde voy a copiar provisoriamente
    "tempDir": "${sys:prop:java.io.tmpdir}/tmpProfSznajdleder",

    -- disco destinatario (toda la instalación será relativa a este disco)
    "targetDrive": "D:",
    
    -- vscode home 
    "vscodeHome": "${targetDrive}/vscode",
    
    -- vscode workspace 
    "vscodeWorkspace": "${vscodeHome}/Workspace",

	-- backup del viejo workspace (antes de borrarlo)
    "workspaceBkp":"${sys:prop:user.home}/workspaceBkp_${time:now:yyyyMMdd-HHmm}.zip",	



  	-- ************************ --        
	-- *   TIPO INSTALACIÓN   * --        
    -- ************************ --        
	--                                    
	-- 0: Inicial/Básica  | vscode        
	-- 1: Primer parcial  | vscode+1C.zip 
	-- 2: Segundo parcial | vscode+2C.zip 

	"installType":2
  },  

  "steps": [    
    
	-- **************** --
	-- * Copio al tmp *   
	-- **************** --
		
	-- 1: vscode 
    { "action":"FileCopy",
	  "from":"${sourceDir}/${vscodeZip}",
	  "to":"${tempDir}/",
	  "executeIf":"notExistsOrIsNewer",
	  "showProgress": true
	},

	-- 2: workspaceConfigFile 
    { "action":"FileCopy",
	  "from":"${sourceDir}/${workspaceConfigFile}",
	  "to":"${tempDir}/",
	  "ifvar":"${installType} in (1,2)",
	  "executeIf":"notExistsOrIsNewer",
	  "showProgress": true
	},
	  
	-- 3: 1C.zip 
    { "action":"FileCopy",
	  "from":"${sourceDir}/${fullProject1C}",
	  "to":"${tempDir}/",
	  "ifvar":"${installType}==1",
	  "executeIf":"notExistsOrIsNewer",
	  "showProgress": true
	},
	
	-- 4: copio 2C.zip a tmp SI installType==2 
    { "action":"FileCopy",
	  "from":"${sourceDir}/${fullProject2C}",
	  "to":"${tempDir}/",
	  "ifvar":"${installType}==2",
	  "executeIf":"notExistsOrIsNewer",
	  "showProgress": true
	},
	
	-- **************** --
	-- * Backup y rmv *   
	-- **************** --

    -- 5: workspaceBkp 
    { "action": "Zip", 
	  "from":"${vscodeWorkspace}",
	  "to":"${workspaceBkp}",
	  "showProgress":true,
	  "stopScriptOnError":false
	},
    
    -- 6: Rmv anterior 
    { "action":"Remove",
	  "from":"${vscodeHome}",
	  "showProgress":true,
	  "stopScriptOnError":false
	},
	
	-- **************** --
	-- * Inst. VSCode * --
	-- **************** --

    -- 7: unzip vsCode 
    { "action":"Unzip",
	  "from":"${tempDir}/${vscodeZip}",
	  "to":"${targetDrive}/",
	  "showProgress": true 
	},

	-- **************** --
	-- *  Parciales   * --
	-- **************** --
	  
	-- 8: rmv helloWorldProject 
    { 
	  "action":"Remove",
	  "from":"${vscodeWorkspace}/${helloWorldProject}",
	  "ifvar":"${installType} in (1,2)",
	  "showProgress":true,
	  "stopScriptOnError":false
	},
	  
	-- 9: unzip 1C 
    { 
	  "action":"Unzip",
	  "from":"${tempDir}/${fullProject1C}",
	  "to":"${vscodeWorkspace}/",
	  "ifvar":"${installType}==1",
	  "showProgress": true 
	},

	-- 10: unzip 2C 
    { 
	  "action":"Unzip",
	  "from":"${tempDir}/${fullProject2C}",
	  "to":"${vscodeWorkspace}/",
	  "ifvar":"${installType}==2",
	  "showProgress": true 
	},
	
	-- 11: fileCopy workspaceConfigFile
    { 
	  "action":"FileCopy",
	  "from":"${tempDir}/${workspaceConfigFile}",
	  "to":"${vscodeWorkspace}/",
	  "ifvar":"${installType} in (1,2)",
	  "showProgress": true
	},	  

    -- 12: levanto vscode 
    { "action":"Exec","command":"${vscodeHome}/RunVSCode.bat" }
  ]
}
